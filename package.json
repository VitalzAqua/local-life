{
  "name": "local-life-platform",
  "version": "1.0.0",
  "description": "Local Life Platform - Full Stack Application",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web,driver -c blue,green,magenta \"npm run dev:backend\" \"npm run dev:frontend\" \"npm run dev:driver\"",
    "dev:backend": "cd backend && npm run dev",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:driver": "cd driver-assignment-service && npm run dev",
    "build": "cd frontend && npm run build",
    "start": "cd backend && npm start",
    "test": "cd backend && npm test",
    "verify": "npm test && npm run build",
    "env:copy": "sh scripts/copy-env.sh",
    "db:init": "sh scripts/init-local-db.sh",
    "db:seed:stores": "sh scripts/init-local-db.sh --with-stores",
    "setup:local": "npm run env:copy && npm run install:all",
    "install:backend": "cd backend && npm install",
    "install:frontend": "cd frontend && npm install",
    "install:driver": "cd driver-assignment-service && npm install",
    "install:all": "npm run install:backend && npm run install:frontend && npm run install:driver"
  },
  "keywords": ["local", "life", "platform", "stores", "restaurants", "reservations"],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  }
} 
