# Copy to .env and fill in real values. Never commit .env.

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/local_life

# Server
PORT=3001
NODE_ENV=development

# Optional. For a separately hosted frontend, set one or more allowed origins.
# Leave unset if the frontend and backend are deployed on the same origin.
# Example: https://locallife.example.com,https://admin.locallife.example.com
CORS_ORIGIN=http://localhost:3000

# Driver assignment service base URL used by the backend when assigning orders
DRIVER_ASSIGNMENT_SERVICE_URL=http://localhost:3002

# Token signing and session expiry
JWT_SECRET=replace-this-with-a-long-random-secret
USER_TOKEN_TTL=7d
ADMIN_TOKEN_TTL=4h

# Database pool (optional; defaults exist in code)
DB_POOL_SIZE=10
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# Shared secret used only for backend admin login
ADMIN_CODE=your-secure-admin-code
