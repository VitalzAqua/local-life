# Copy to .env and fill in real values. Never commit .env.

# Same database as the main backend
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/local_life

# HTTP port for this service
DRIVER_SERVICE_PORT=3002
NODE_ENV=development

# Database pool (optional)
DB_POOL_SIZE=5
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=60000

# Assignment tuning (optional)
MAX_ASSIGNMENT_DISTANCE=50
ASSIGNMENT_TIMEOUT=5000
ASSIGNMENT_RETRIES=3
